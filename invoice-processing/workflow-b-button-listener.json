      "parameters": {
        "jsCode": "// Slack stuurt de data ingepakt\nconst payload = JSON.parse($input.item.json.body.payload);\nconst buttonValue = payload.actions[0].value; \nconst user = payload.user.username || \"Iemand\";\nconst userId = payload.user.id;\n\n// LOGICA OM HET ID TE VINDEN\nlet recordId = buttonValue;\n\nif (buttonValue && buttonValue.includes(\"__\")) {\n    const parts = buttonValue.split(\"__\");\n    recordId = parts[1];\n}\n\nif (!recordId) {\n    throw new Error(\"Geen Record ID gevonden in de knop: \" + buttonValue);\n}\n\n// HIER ZIT DE FIX: We retourneren een Array met een json object\nreturn [\n  {\n    json: {\n      action_id: payload.actions[0].action_id,\n      full_string: buttonValue,\n      clean_record_id: recordId,\n      user: user,\n      user_id: userId,\n      channel_id: payload.channel.id,\n      message_ts: payload.message.ts\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
