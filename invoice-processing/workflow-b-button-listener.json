    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\n\n// Haal bedrag en BTW op\nlet totaalBedrag = parseFloat(data.Bedrag) || 0;\nlet btwBedrag = parseFloat(data.BTW) || 0;\n\n// Bereken het bedrag EXCLUSIEF BTW\nlet bedragExclBtw = totaalBedrag - btwBedrag;\nbedragExclBtw = bedragExclBtw.toFixed(2);\n\n// Datum formatteren\nconst datum = data.Datum || new Date().toISOString().split('T')[0];\n\n// Leveranciersnaam\nconst naam = (data['Naam (from Leverancier)'] && data['Naam (from Leverancier)'][0]) || 'Onbekend';\n\n// Factuurnummer\nconst factuurnummer = data.Factuurnummer || 'Geen kenmerk';\n\nconst body = {\n  purchase_invoice: {\n    contact_id: \"475440760197481862\",\n    reference: factuurnummer,\n    date: datum,\n    details_attributes: [\n      {\n        description: `Factuur van ${naam}`,\n        price: bedragExclBtw,  // ← Nu EXCLUSIEF BTW\n        tax_rate_id: \"475257263575008816\"\n      }\n    ]\n  }\n};\n\nconsole.log(\"Sending to Moneybird:\", JSON.stringify(body, null, 2));\nconsole.log(`Bedrag incl BTW: €${totaalBedrag}, BTW: €${btwBedrag}, Excl BTW: €${bedragExclBtw}`);\n\nreturn body;"
      },
