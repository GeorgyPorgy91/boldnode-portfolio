      "parameters": {
        "jsCode": "// 1. Haal de resultaten van de AI op (huidige input)\nconst aiResults = items;\n\n// 2. Haal de ORIGINELE klantdata op (van de node vóór de AI)\n// Let op: Zorg dat de naam tussen haakjes exact klopt met je node naam\nlet originalData = [];\ntry {\n  originalData = $('Deduplication Firewall').all();\n} catch (error) {\n  // Fallback voor als je test zonder de hele flow\n  originalData = aiResults; \n}\n\nreturn aiResults.map((item, index) => {\n  // 3. Zoek de tekst van Gemini (waar hij ook verstopt zit)\n  const root = item.json;\n  const rawText = root.text || root.output || root.response || (root.generations ? root.generations[0][0].text : \"\") || JSON.stringify(root);\n\n  let finalIntentie = \"HANDMATIG\";\n  let finalSentiment = \"NEUTRAAL\";\n\n  // 4. De \"Regex\" grijper: Vis de JSON eruit\n  const jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n\n  if (jsonMatch) {\n    try {\n      const cleanData = JSON.parse(jsonMatch[0]);\n      if (cleanData.intentie) finalIntentie = cleanData.intentie.toString().toUpperCase();\n      if (cleanData.sentiment) finalSentiment = cleanData.sentiment.toString().toUpperCase();\n    } catch (e) {\n      // JSON stuk, jammer dan -> handmatig\n    }\n  }\n\n  // 5. DE SAMENVOEGING (Merge)\n  // We pakken de originele data (Naam/Email) van de juiste index\n  // En plakken daar de nieuwe AI output aan vast\n  const customerData = originalData[index] ? originalData[index].json : {};\n\n  return {\n    json: {\n      ...customerData,  // <--- Hier herstellen we Naam, Email, Bericht!\n      output: {\n        intentie: finalIntentie,\n        sentiment: finalSentiment\n      }\n    }\n  };\n});"
      },
