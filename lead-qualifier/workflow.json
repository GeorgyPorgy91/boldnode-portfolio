      "parameters": {
        "jsCode": "// We simuleren hier EXACT de structuur die Tally verstuurt.\n// Zo hoeven we de rest van de workflow niet aan te passen.\n\nreturn [\n  // SCENARIO 1: Een blije Sales lead\n  {\n    json: {\n      body: {\n        data: {\n          fields: [\n            { value: \"Test Jan (Sales)\" },              // Index 0: Naam\n            { value: \"jan.test@bedrijf.nl\" },           // Index 1: Email\n            { value: \"Ik wil graag de Enterprise versie kopen!\" } // Index 2: Bericht\n          ]\n        }\n      }\n    }\n  },\n  // SCENARIO 2: Een boze Support klant\n  {\n    json: {\n      body: {\n        data: {\n          fields: [\n            { value: \"Test Els (Support)\" },            // Index 0: Naam\n            { value: \"els.test@klacht.nl\" },            // Index 1: Email\n            { value: \"Mijn inlog werkt niet en ik ben boos.\" }   // Index 2: Bericht\n          ]\n        }\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
