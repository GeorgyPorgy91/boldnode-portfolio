        "jsCode": "// 1. Haal de tekst op\nconst content = $input.first().json.output[0].content[0].text;\n\n// 2. Zoek met een 'Regex' naar het gedeelte tussen de accolades { ... }\nconst jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n\nif (jsonMatch) {\n  try {\n    // 3. Parse alleen het gevonden stukje\n    const parsed = JSON.parse(jsonMatch[0]);\n    return [parsed];\n  } catch (e) {\n    return [{ error: \"JSON gevonden maar corrupt\", raw: content }];\n  }\n} else {\n  return [{ error: \"Geen JSON gevonden in de tekst\", raw: content }];\n}"
      },
